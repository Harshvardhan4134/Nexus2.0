{
  "manifest_version": 3,
  "name": "Nexus Agent (in-tab)",
  "version": "0.0.2",
  "description": "Runs Nexus-style tasks in your current Chrome tab via a content script (no Playwright server).",
  "action": {
    "default_title": "Open Nexus Agent"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "alarms", "scripting", "sidePanel", "storage", "tabs"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
