{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const fs=require('fs');for(const f of['package-lock.json','yarn.lock']){try{fs.unlinkSync(f)}catch{}}const ua=process.env.npm_config_user_agent||'';if(!ua.includes('pnpm/')){console.error('Use pnpm instead');process.exit(1)}\"",
    "firebase": "firebase",
    "firebase:emulators": "firebase emulators:start --only firestore",
    "firebase:login": "firebase login",
    "firebase:use": "firebase use",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "firebase-tools": "^14.24.0",
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
